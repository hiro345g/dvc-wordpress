# msmtp system-wide configuration file.

# Default values
defaults
auth           off
tls            off
tls_starttls   off
# ログを標準出力に送る (コンテナのベストプラクティス)
logfile        /dev/stdout
# RFC 2822 に準拠していない From ヘッダを書き換える
set_from_header on
# From ヘッダがない場合に使用するアドレス
from           www-data@localhost

# Mailpit account
account        mailpit
host           mailpit
port           1025

# Set mailpit as default
account default : mailpit
